# ══════════════════════════════════════════════════════════════════════
# AI Engineering Org Pulse — Environment Variables
#
# Platform-level variables (ADMIN_EMAILS, JIRA_*, GITHUB_*, GITLAB_*,
# IPA_*, GOOGLE_SERVICE_ACCOUNT_KEY_FILE) are documented in the core
# package: node_modules/@org-pulse/core/.env.example
# ══════════════════════════════════════════════════════════════════════

# Demo Mode (set both to 'true' to run without any credentials)
# DEMO_MODE=true
# VITE_DEMO_MODE=true

# ══════════════════════════════════════════════════════════════════════
# Platform Configuration (non-secret settings)
# ══════════════════════════════════════════════════════════════════════

ADMIN_EMAILS=you@redhat.com
JIRA_HOST=https://redhat.atlassian.net
JIRA_EMAIL=you@redhat.com
JIRA_TOKEN=your-jira-api-token
GITHUB_TOKEN=your-github-pat

# ══════════════════════════════════════════════════════════════════════
# Module: releases
# ══════════════════════════════════════════════════════════════════════

# Product Pages OAuth (production — service account)
# PRODUCT_PAGES_CLIENT_ID=
# PRODUCT_PAGES_CLIENT_SECRET=
# Product Pages personal token (local dev fallback — exclusive with OAuth above)
# PRODUCT_PAGES_TOKEN=

# Feature Traffic GitLab token (optional - overrides GITLAB_TOKEN for CI artifact fetching)
# FEATURE_TRAFFIC_GITLAB_TOKEN=

# SmartSheet API token (for release discovery)
# SMARTSHEET_API_TOKEN=your-smartsheet-api-token

# ── Releases configuration (non-secret) ──

# SMARTSHEET_SHEET_ID=3025228340193156
# PRODUCT_PAGES_BASE_URL=https://productpages.redhat.com

# Release Analysis: Extra JQL filters for velocity queries, keyed by project. JSON object.
# RELEASE_ANALYSIS_VELOCITY_EXTRA_JQL_BY_PROJECT={"AIPCC":"issuetype = Epic AND labels = package"}

# Release Analysis: Target Version field and JQL fragment
# RELEASE_ANALYSIS_TARGET_VERSION_FIELD=customfield_10855
# RELEASE_ANALYSIS_TARGET_VERSION_JQL_FRAGMENT=cf[10855] is not EMPTY

# ══════════════════════════════════════════════════════════════════════
# Module: upstream-pulse (non-secret configuration)
# ══════════════════════════════════════════════════════════════════════

# Defaults to in-cluster service URL. Set for local dev when port-forwarding.
# UPSTREAM_PULSE_API_URL=http://localhost:4321

# ══════════════════════════════════════════════════════════════════════
# Module: product-builds (non-secret configuration)
# ══════════════════════════════════════════════════════════════════════

# AIPCC Dashboard API base URL (can also be configured via Settings UI)
# PRODUCT_BUILDS_API_URL=

# ══════════════════════════════════════════════════════════════════════
# Module: customer-insights
# ══════════════════════════════════════════════════════════════════════

# Google OAuth credentials for customer-insights module
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_PICKER_API_KEY=
# VITE_GOOGLE_PICKER_API_KEY=

# Granite AI API credentials for AI Insights
# MODELS_CORP_API_KEY=
# MODELS_CORP_BASE_URL=

# Jira OAuth credentials for per-user RFE creation
# JIRA_OAUTH_CLIENT_ID=
# JIRA_OAUTH_CLIENT_SECRET=

# Demo Mode (set both to 'true' to run without Jira/GitHub credentials)
# DEMO_MODE=true
# VITE_DEMO_MODE=true

# Jira Cloud Configuration (not needed in demo mode)
JIRA_EMAIL=you@redhat.com
JIRA_TOKEN=your-jira-api-token
JIRA_HOST=https://redhat.atlassian.net

# GitHub personal access token (for contribution stats)
GITHUB_TOKEN=your-github-pat

# Admin emails (comma-separated, used to seed the allowlist)
ADMIN_EMAILS=you@redhat.com

# API Endpoint (optional - defaults to /api which proxies to local dev server)
# VITE_API_ENDPOINT=

# GitLab Configuration (optional - defaults to gitlab.com, token strongly recommended)
# GITLAB_TOKEN=           # Personal access token with read_api scope (strongly recommended for rate limits)
# GITLAB_BASE_URL=        # Optional, defaults to https://gitlab.com

# Local dev server port (optional - defaults to 3001)
# API_PORT=3001

# Proxy auth secret (optional - when set, backend requires X-Proxy-Secret header)
# Used in production: nginx injects this header when proxying to the backend.
# PROXY_AUTH_SECRET=

# Google Sheets service account key file (for roster sync)
# GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./secrets/google-sa-key.json

# Upstream Pulse API URL (optional - for the upstream-pulse module)
# Defaults to in-cluster service URL. Set for local dev when port-forwarding.
# UPSTREAM_PULSE_API_URL=http://localhost:4321

+    if (item) selectItem(item)
+  }
+}
+
+function onResize() { windowWidth.value = window.innerWidth }
+
+onMounted(() => {
+  window.addEventListener('resize', onResize)
+  nextTick(() => {
+    inputRef.value?.focus()
+  })
+})
+
+onBeforeUnmount(() => {
+  window.removeEventListener('resize', onResize)
+  resetSelection()
+})
+</script>

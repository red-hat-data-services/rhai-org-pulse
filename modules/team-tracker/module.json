{
  "name": "Team Tracker",
  "slug": "team-tracker",
  "description": "Delivery metrics, sprint tracking, and team insights",
  "icon": "bar-chart",
  "order": 0,
  "client": {
    "entry": "./client/index.js",
    "navItems": [
      { "id": "dashboard", "label": "Dashboard", "icon": "BarChart3", "default": true },
      { "id": "people", "label": "People", "icon": "Users" },
      { "id": "trends", "label": "Trends", "icon": "TrendingUp" },
      { "id": "reports", "label": "Reports", "icon": "FileText" }
    ],
    "settingsComponent": "./client/components/TeamTrackerSettings.vue"
  },
  "server": {
    "entry": "./server/index.js"
  },
  "defaultEnabled": true,
  "requires": [],
  "export": {
    "customHandler": true,
    "files": [
      { "path": "org-roster-full.json", "notes": "Nested VP/orgs/leaders/members" },
      { "path": "people/*.json", "notes": "Per-person Jira metrics" },
      { "path": "github-contributions.json", "notes": "GitHub contribution counts" },
      { "path": "github-history.json", "notes": "Monthly GitHub history" },
      { "path": "gitlab-contributions.json", "notes": "GitLab contribution counts" },
      { "path": "gitlab-history.json", "notes": "Monthly GitLab history" },
      { "path": "snapshots/**/*.json", "notes": "Team snapshots" },
      { "path": "jira-name-map.json", "notes": "Jira accountId cache" }
    ]
  }
}
